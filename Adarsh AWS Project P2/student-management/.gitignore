# ==================================================
# GIT IGNORE RULES: .gitignore
# AWS Cloud-Based Student Management System
# ==================================================

# Compiled Python files
__pycache__/
*.py[cod]
*$py.class

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Fallback databases
*.db
*.sqlite

# Upload assets (documents and photos)
uploads/*
!uploads/.gitkeep

# System Log directories
logs/*
!logs/.gitkeep

# Operating system metadata
.DS_Store
Thumbs.db
