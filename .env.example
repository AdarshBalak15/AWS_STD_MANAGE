# ==================================================
# ENVIRONMENT CONFIGURATION TEMPLATE: .env.example
# AWS Student Management System
# ==================================================

# Flask Setup
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=generate-a-long-random-string-for-session-cookie-encryption

# DB Setup (Choose 'mysql' for AWS RDS or 'sqlite' for fallback)
DB_TYPE=sqlite
RDS_HOSTNAME=educloud-db-instance.xxxxxx.us-east-1.rds.amazonaws.com
RDS_USERNAME=admin
RDS_PASSWORD=supersecurepassword123
RDS_DB_NAME=educloud_db
RDS_PORT=3306

# Storage Provider (Choose 's3' for AWS uploads or 'local' for filesystem storage)
STORAGE_PROVIDER=local
AWS_S3_BUCKET=educloud-student-transcripts-bucket
AWS_S3_USE_IAM_ROLE=False

# AWS General Access Keys (Optional if running on EC2 instance with IAM profile roles)
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1

# AWS SNS Configuration (Dispatches email on document upload)
AWS_SNS_ENABLED=False
AWS_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:educloud-notification-topic
AWS_SNS_USE_IAM_ROLE=False

# AWS Lambda Configuration (Triggered by S3 event for profile image resize)
AWS_LAMBDA_ENABLED=False
AWS_LAMBDA_USE_IAM_ROLE=False
AWS_LAMBDA_IMAGE_RESIZE_NAME=educloud-image-resize

# AWS CloudWatch Configuration
AWS_CLOUDWATCH_ENABLED=False
AWS_CLOUDWATCH_LOG_GROUP=educloud/student-management-system
AWS_CLOUDWATCH_LOG_STREAM=app-logs
